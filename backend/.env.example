# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (Render sets DATABASE_URL automatically)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.onrender.com

# Database
DB_NAME=truthlens_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Media files
MEDIA_ROOT=media/
MEDIA_URL=/media/

# Max upload sizes (bytes)
MAX_IMAGE_SIZE=10485760   # 10 MB
MAX_VIDEO_SIZE=104857600  # 100 MB
MAX_TEXT_LENGTH=50000

# ── OCR (Tesseract) ────────────────────────────────────────────────────
# Windows: TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux/macOS: leave blank (uses system PATH)
TESSERACT_CMD=
TESSERACT_LANG=eng

# ── Speech-to-Text (Whisper + ffmpeg) ─────────────────────────────────
# Model size: tiny | base | small | medium | large  (default: small)
WHISPER_MODEL_SIZE=small
# Force language (ISO-639-1) or leave blank for auto-detection
WHISPER_LANGUAGE=
# Full paths to ffmpeg / ffprobe — leave blank to use system PATH
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ── Fact-check sources ─────────────────────────────────────────────────
# Shared HTTP timeout (seconds) for all source connectors
SOURCE_REQUEST_TIMEOUT=15
HTTP_SSL_VERIFY=True

# GNews API (free tier: 100 req/day)
# Sign up: https://gnews.io/
GNEWS_API_KEY=your-gnews-api-key-here
GNEWS_MAX_RESULTS=5
GNEWS_LANGUAGE=en
GNEWS_COUNTRY=

# Google FactCheck API (free tier)
GOOGLE_FACTCHECK_API_KEY=your-google-api-key-here
